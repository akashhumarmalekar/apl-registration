<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<style>
  :root {
    --navy-900: #071426;
    --navy-800: #0B1F3A;
    --navy-700: #14304F;
    --navy-600: #1D4267;
    --gold-500: #D4AF37;
    --gold-400: #F2C94C;
    --green-700: #15573B;
    --green-500: #1F7A4D;
    --cream-100: #F7F5F0;
    --white: #FFFFFF;
