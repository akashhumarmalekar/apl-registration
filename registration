  }
  .hero__inner { max-width: 520px; margin: 0 auto; padding: 40px 20px 28px; }
  .hero__eyebrow {
    display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-mono);
    font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--gold-400);
