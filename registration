  }
  * { box-sizing: border-box; }
  #apl-root {
    font-family: var(--font-body);
    background: var(--cream-100);
    color: var(--ink);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  #apl-root .page__inner { width: 100%; max-width: 520px; padding-bottom: 48px; }

  /* Hero */
  .hero {
    width: 100%;
