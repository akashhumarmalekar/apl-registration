/* ============================================================
   Global layout
   ============================================================ */

.page {
  min-height: 100%;
  background: var(--cream-100);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.page__inner {
  width: 100%;
  max-width: 560px;
  padding: 0 0 var(--space-8);
}

/* ============================================================
   Hero — "matchday ticket"
   The signature element: the event card is built like a physical
   cricket-match ticket stub, complete with a perforated tear line
   joining it to the registration form below.
   ============================================================ */

.hero {
  width: 100%;
  background:
    radial-gradient(circle at 18% -10%, rgba(212, 175, 55, 0.16), transparent 45%),
    radial-gradient(circle at 100% 0%, rgba(31, 122, 77, 0.22), transparent 50%),
    linear-gradient(160deg, var(--navy-900) 0%, var(--navy-800) 55%, var(--navy-700) 100%);
  padding: env(safe-area-inset-top, 0) 0 0;
  position: relative;
  overflow: hidden;
}

.hero::before {
  /* faint pitch-stripe texture across the hero */
  content: '';
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    100deg,
    rgba(255, 255, 255, 0.025) 0px,
    rgba(255, 255, 255, 0.025) 2px,
    transparent 2px,
    transparent 64px
  );
  pointer-events: none;
}

.hero__inner {
  position: relative;
  max-width: 560px;
  margin: 0 auto;
  padding: var(--space-7) var(--space-5) var(--space-6);
}

.hero__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  font-family: var(--font-mono);
  font-size: 12px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--gold-400);
  background: rgba(212, 175, 55, 0.12);
  border: 1px solid rgba(212, 175, 55, 0.35);
  padding: 6px 12px;
  border-radius: var(--radius-pill);
  margin-bottom: var(--space-4);
  animation: fadeInUp 0.6s ease both;
}

.hero__title {
  font-family: var(--font-display);
  font-weight: 400;
  font-size: clamp(40px, 11vw, 56px);
  line-height: 0.98;
  letter-spacing: 0.01em;
  color: var(--on-dark);
  margin: 0 0 var(--space-5);
  text-shadow: 0 4px 24px rgba(0, 0, 0, 0.35);
  animation: fadeInUp 0.6s ease 0.08s both;
}

.hero__title em {
  font-style: normal;
  color: var(--gold-400);
}

/* Ticket stub */
.ticket {
  background: linear-gradient(135deg, var(--navy-700), var(--navy-800));
  border: 1px solid rgba(212, 175, 55, 0.3);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-lg);
  display: flex;
  position: relative;
  animation: fadeInUp 0.6s ease 0.16s both;
}

.ticket__main {
  flex: 1;
  padding: var(--space-5);
  display: grid;
  gap: var(--space-3);
}

.ticket__row {
  display: flex;
  align-items: center;
  gap: var(--space-3);
}

.ticket__icon {
  width: 34px;
  height: 34px;
  flex-shrink: 0;
  border-radius: 10px;
  background: rgba(212, 175, 55, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 17px;
}

.ticket__label {
  font-family: var(--font-mono);
  font-size: 10.5px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--on-dark-muted);
  margin: 0 0 2px;
}

.ticket__value {
  font-family: var(--font-body);
  font-weight: 700;
  font-size: 15.5px;
  color: var(--on-dark);
  margin: 0;
}

.ticket__stub {
  width: 76px;
  flex-shrink: 0;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  border-left: 2px dashed rgba(212, 175, 55, 0.45);
}

.ticket__stub::before,
.ticket__stub::after {
  content: '';
  position: absolute;
  width: 20px;
  height: 20px;
  background: var(--cream-100);
  border-radius: 50%;
  left: -11px;
}

.ticket__stub::before { top: -10px; }
.ticket__stub::after { bottom: -10px; }

.ticket__vertical {
  writing-mode: vertical-rl;
  transform: rotate(180deg);
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.25em;
  color: var(--gold-400);
  text-transform: uppercase;
  white-space: nowrap;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(14px); }
  to { opacity: 1; transform: translateY(0); }
}

@media (prefers-reduced-motion: reduce) {
  .hero__eyebrow, .hero__title, .ticket { animation: none; }
}
