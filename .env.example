# Copy this file to .env (for local dev) and add the same keys as
# Environment Variables in your Vercel project settings for deployment.
# Never commit your real .env file.

# Supabase project config — get these from
# Supabase Dashboard > Project Settings > API
# (The anon/public key is safe to ship to the browser — see schema.sql for
# how access is actually controlled via Row Level Security policies.)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# The live URL of the deployed app once it's on Vercel (used to generate
# the QR code shown on the admin page). Example: https://apl-registration.vercel.app
VITE_APP_URL=

# Password for the /admin dashboard. Keep this private — see README for
# notes on its security model.
VITE_ADMIN_PASSWORD=
